<Application x:Class="SmoothAutoRun.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF6B35"/>
        <SolidColorBrush x:Key="BgDarkBrush" Color="#1E1E2E"/>
        <SolidColorBrush x:Key="BgLightBrush" Color="#F0F0F5"/>
        <SolidColorBrush x:Key="SidebarDarkBrush" Color="#252536"/>
        <SolidColorBrush x:Key="SidebarLightBrush" Color="#E8E8F0"/>
        <SolidColorBrush x:Key="TextDarkBrush" Color="#CDD6F4"/>
        <SolidColorBrush x:Key="TextLightBrush" Color="#1E1E2E"/>
    </Application.Resources>
</Application>